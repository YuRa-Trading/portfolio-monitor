# Trading 212 API credentials
# Get these from Trading 212 → Settings → API (beta)
T212_API_KEY=your-api-key-here
T212_API_SECRET=your-api-secret-here

# Environment: "live" or "demo"
T212_ENVIRONMENT=demo

# Finnhub API key (optional — enables earnings calendar)
# Register free at https://finnhub.io/register
FINNHUB_API_KEY=your-finnhub-api-key-here
